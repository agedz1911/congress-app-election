[program:election-app-horizon]
process_name=%(program_name)s
directory=/var/www/election-app
command=/usr/bin/php artisan horizon
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=www-data
redirect_stderr=true
stdout_logfile=/var/www/election-app/storage/logs/horizon.log
stdout_logfile_maxbytes=20MB
stdout_logfile_backups=10
stopwaitsecs=3600
environment=APP_ENV="production",QUEUE_CONNECTION="redis"